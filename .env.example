NEXT_PUBLIC_APP_NAME="HazardSignal"
NEXT_PUBLIC_BASE_URL=https://hazardsignal.com
NEXT_PUBLIC_EE_APP_URL=https://code.earthengine.google.com/
WEB_PORT=3000

WORKER_PORT=8080
WORKER_HOST=127.0.0.1
WORKER_INTERNAL_TOKEN=
WORKER_TIMEZONE=Europe/Istanbul
WORKER_RUN_HOUR=08
WORKER_USE_MOCK_EE=true
WORKER_EXPORT_BEFORE_RUN=false
APP_PUBLIC_URL=https://hazardsignal.com
HEALTHCHECK_PUBLIC_URL=https://hazardsignal.com

EE_PROJECT_ID=wildfire-540
EE_SERVICE_ACCOUNT_KEY_PATH=/home/zico/opt/fire-risk/secrets/earthengine-service-account.json
EE_ASSET_ROOT=projects/wildfire-540/assets/fire_risk_ops
EE_ASSET_NAME_PREFIX=antalya_fire_risk
# Leave classifier asset ids empty while using dynamic_training_only.
EE_CLASSIFIER_ASSET_ID=
EE_CLASSIFIER_FALLBACK_ASSET_ID=
# Only relevant if you later switch back to classifier_asset_* strategies.
EE_CLASSIFIER_OUTPUT_MODE=CLASSIFICATION
EE_RISK_OUTPUT_STRATEGY=dynamic_training_only
EE_ALLOW_DYNAMIC_TRAINING_FALLBACK=true
EE_ALLOW_HEURISTIC_FALLBACK=true
EE_LABEL_WINDOW_DAYS=365
EE_FIRE_EXPAND_PIXELS=1
EE_TRAIN_SAMPLES_PER_CLASS=1200
EE_TRAIN_NEG_TO_POS_RATIO=1
EE_TRAIN_SEED=42
EE_TRAIN_MIN_SAMPLES_PER_CLASS=50
EE_FALLBACK_RF_TREES=80
EE_ASSET_DATE_POLICY=latest_available
EE_MAX_ASSET_AGE_DAYS=30
EE_CLOUD_THRESHOLD=20
EE_SCALE=1000
EE_WINDOW_MODE=weekly
EE_FEATURE_WINDOW_DAYS=7
EE_CUSTOM_WINDOW_DAYS=30
EE_CORRIDOR_LOOKBACK_YEARS=5
EE_MAX_DISTANCE_METERS=50000
EE_USE_ROAD_DISTANCE=false
EE_ROADS_ASSET_PATH=
EE_CLASS_BREAK1=0.20
EE_CLASS_BREAK2=0.40
EE_CLASS_BREAK3=0.60
EE_CLASS_BREAK4=0.80
EE_EXPORT_OVERWRITE=false
EE_EXPORT_POLL_SECONDS=30
EE_EXPORT_TIMEOUT_MINUTES=180
EE_REGION_COUNTRY=Turkey
EE_REGION_LEVEL1=Antalya
EE_SELECTED_MODEL=RandomForest
EE_SELECTED_THRESHOLD=0.5
EE_APPROVED_FIRE_F1=0.87
EE_APPROVED_BALANCED_ACCURACY=0.90
EE_DOWNLOAD_BASE_URL=

# NASA FIRMS direct API for active fire hotspots
# Get a free map key at https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_ENABLED=true
FIRMS_MAP_KEY=
FIRMS_SATELLITE=VIIRS_SNPP_NRT
FIRMS_BBOX=29.3,36.0,32.5,37.5
FIRMS_DAYS=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=wildfire_risk_bot
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

GITHUB_WEBHOOK_SECRET=

# Weather (Open-Meteo — free, no API key required)
OWM_ENABLED=true
OWM_LAT=36.8969
OWM_LON=30.7133

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@hazardsignal.com
ADMIN_DASHBOARD_PASSWORD=
ADMIN_SESSION_SECRET=

# If these are set, web + worker will use Supabase instead of data/mock.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=